# Developer machine — set by scripts/setup.sh
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
ENABLE_BETA_TRACING_DETAILED=true
PROMPTLENS_ENDPOINT=http://localhost:8000
# PROMPTLENS_DEVELOPER_ID is generated by setup.sh from machine UUID
PROMPTLENS_DEVELOPER_ID=
PROMPTLENS_TEAM_ID=default
PROMPTLENS_STREAK_WARN=5

# Backend
# APP_ENV options: development | production | test
# production mode enforces all required vars at startup
APP_ENV=development
LOG_LEVEL=INFO
DATABASE_URL=postgresql://promptlens:promptlens@localhost:5432/promptlens
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
REDIS_URL=redis://localhost:6379/0
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
SLACK_WEBHOOK_URL=
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=dev-secret-change-in-prod
AWS_REGION=ap-south-1
