# Developer machine — set by scripts/setup.sh
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
ENABLE_BETA_TRACING_DETAILED=true
PROMPTLENS_ENDPOINT=http://localhost:8000
PROMPTLENS_DEVELOPER_ID=           # SHA-256(machine_uuid) — set by setup.sh
PROMPTLENS_TEAM_ID=default
PROMPTLENS_STREAK_WARN=5

# Backend
DATABASE_URL=postgresql://promptlens:promptlens@localhost:5432/promptlens
REDIS_URL=redis://localhost:6379/0
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
SLACK_WEBHOOK_URL=
JWT_SECRET=                        # generate: openssl rand -hex 32
AWS_REGION=ap-south-1
